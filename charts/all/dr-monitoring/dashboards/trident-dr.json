        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "State" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background",
                  "mode": "basic"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Established": { "color": "green", "text": "Established" }, "Establishing": { "color": "yellow", "text": "Establishing" }, "Promoted": { "color": "blue", "text": "Promoted" }, "Failed": { "color": "red", "text": "Failed" } } }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Desired" },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "Established": { "color": "green" }, "Promoted": { "color": "blue" } } }
                ]
              }
            ]
          }
