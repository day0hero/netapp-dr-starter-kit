          "mappings": [
            { "type": "value", "options": { "0": { "text": "Not Established" }, "1": { "text": "Established" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "min": 0,
          "max": 1
