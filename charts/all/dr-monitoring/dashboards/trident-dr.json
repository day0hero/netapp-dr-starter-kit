        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "trident_amr_current_state{current_state_value=\"Established\"}",
          "legendFormat": "{{ namespace }}/{{ name }}",
          "refId": "A"
        }
      ]
