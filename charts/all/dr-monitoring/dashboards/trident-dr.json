          "legendFormat": "",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "container": true,
              "endpoint": true,
              "instance": true,
              "job": true,
              "pod": true,
              "service": true,
              "uid": true,
              "prometheus": true,
              "prometheus_replica": true
            },
            "indexByName": {},
            "renameByName": {
              "name": "Name",
              "namespace": "Namespace",
              "desired_state": "Desired",
              "state": "State",
              "source_app": "Source App",
              "source_app_vault": "Source Vault",
              "destination_app_vault": "Dest Vault",
              "storage_class": "Storage Class"
